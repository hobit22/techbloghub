{
  "name": "techbloghub",
  "version": "1.0.0",
  "description": "국내 IT 기업 기술블로그를 한 곳에서 모아보는 플랫폼입니다. RSS 피드를 기반으로 자동으로 포스트를 수집하고, AI를 활용한 콘텐츠 요약 생성으로 원하는 주제의 글을 쉽게 찾을 수 있습니다.",
  "main": "index.js",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint",
    "backend:dev": "uvicorn main:app --reload --app-dir fastapi",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:whoami": "wrangler whoami"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hobit22/techbloghub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hobit22/techbloghub/issues"
  },
  "homepage": "https://github.com/hobit22/techbloghub#readme",
  "devDependencies": {
    "wrangler": "^4.79.0"
  },
  "dependencies": {
    "defuddle": "^0.15.0"
  }
}
